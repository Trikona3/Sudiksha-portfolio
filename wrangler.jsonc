{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sudiksha-portfolio",
  "main": ".open-next/worker.js",
  "compatibility_date": "2024-09-27",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "vars": {
    "NODE_VERSION": "20"
  },
  "observability": {
    "enabled": true
  },
  "build": {
    "command": "npx opennextjs-cloudflare build && npx opennextjs-cloudflare populateCache local"
  }
}